{
  "name": "ai-novel-diagnosis",
  "private": true,
  "version": "0.0.0",
  "description": "AI网文诊断台：本地 AI 小说诊断与 AI 拆书工具，找出网文为什么没人追，并生成改稿 Prompt。",
  "license": "MIT",
  "author": "myyimu <xiaoke5211@gmail.com>",
  "homepage": "https://github.com/myyimu/ai-novel-diagnosis#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myyimu/ai-novel-diagnosis.git"
  },
  "bugs": {
    "url": "https://github.com/myyimu/ai-novel-diagnosis/issues"
  },
  "keywords": [
    "ai-novel",
    "ai",
    "llm",
    "artificial-intelligence",
    "webnovel",
    "novel",
    "novel-analysis",
    "book-analysis",
    "novel-diagnosis",
    "webnovel-diagnosis",
    "ai-writing",
    "writing-assistant",
    "relationship-graph",
    "knowledge-graph",
    "prompt-engineering",
    "text-analysis",
    "natural-language-processing",
    "storytelling",
    "writing",
    "writing-tools",
    "one-cli"
  ],
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20.11.0 <21",
    "pnpm": ">=10.14.0 <11"
  },
  "scripts": {
    "dev": "one dev",
    "dev:dry-run": "one dev --dry-run",
    "dev:web": "one dev -p web",
    "dev:api": "one dev -p api",
    "dev:core": "one dev -p ai-core",
    "dev:raw": "pnpm --parallel --filter web --filter api --filter @ai-novel-diagnosis/ai-core --if-present run dev",
    "dev:web:raw": "pnpm --filter web dev",
    "dev:api:raw": "pnpm --filter api dev",
    "dev:core:raw": "pnpm --filter @ai-novel-diagnosis/ai-core dev",
    "one:doctor": "node scripts/one-doctor.mjs",
    "container:prepare": "node scripts/prepare-one-container.mjs",
    "container:dry-run": "pnpm run container:prepare && one container build --dry-run -o json",
    "start:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-local.ps1",
    "doctor": "pnpm run ci && pnpm run container:prepare && pnpm run one:doctor",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "format": "pnpm -r --if-present format",
    "typecheck": "pnpm -r --if-present typecheck",
    "check": "pnpm -r --if-present check",
    "test": "pnpm -r --if-present test",
    "ci": "pnpm run check && pnpm run test && pnpm run build",
    "prepare": "husky",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "latest",
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "husky": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "esbuild"
    ]
  }
}
