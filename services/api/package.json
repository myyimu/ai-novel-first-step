{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "description": "Local API for AI网文诊断台 first-chapter triage, full-book analysis, exports, and graph review.",
  "license": "MIT",
  "author": "",
  "scripts": {
    "predev": "node ../../scripts/run-pnpm.cjs --filter @ai-novel-diagnosis/ai-core build",
    "dev": "nest start --watch",
    "prebuild": "node ../../scripts/run-pnpm.cjs --filter @ai-novel-diagnosis/ai-core build",
    "build": "nest build",
    "pretypecheck": "node ../../scripts/run-pnpm.cjs --filter @ai-novel-diagnosis/ai-core build",
    "start": "nest start",
    "prestart:dev": "node ../../scripts/run-pnpm.cjs --filter @ai-novel-diagnosis/ai-core build",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:cov": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:debug": "node --experimental-vm-modules --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest.js --runInBand",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config ./test/jest-e2e.json",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "format": "oxfmt --check package.json nest-cli.json tsconfig.json tsconfig.build.json drizzle.config.ts src test drizzle",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "ts-node drizzle/seed.ts",
    "lint:fix": "oxlint --fix .",
    "format:fix": "oxfmt --write package.json nest-cli.json tsconfig.json tsconfig.build.json drizzle.config.ts src test drizzle",
    "check": "node ../../scripts/run-pnpm.cjs run lint && node ../../scripts/run-pnpm.cjs run typecheck && node ../../scripts/run-pnpm.cjs run format",
    "check:fix": "node ../../scripts/run-pnpm.cjs run lint:fix && node ../../scripts/run-pnpm.cjs run format:fix"
  },
  "dependencies": {
    "@ai-novel-diagnosis/ai-core": "workspace:*",
    "@electric-sql/pglite": "^0.2.17",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/swagger": "^11.2.6",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "axios": "^1.13.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "pg": "^8.18.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.13",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.2",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "^0.31.8",
    "git-cz": "^4.9.0",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt --write --no-error-on-unmatched-pattern"
    ],
    "*.{json,md,css,scss,html,yml,yaml}": [
      "oxfmt --write --no-error-on-unmatched-pattern"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@ai-novel-diagnosis/ai-core$": "<rootDir>/../../../packages/ai-core/src/index.ts"
    },
    "rootDir": "src",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    }
  },
  "packageManager": "pnpm@10.14.0"
}
