# Server
PORT=3000

# Database (可选 — 留空时启动跳过 DB 初始化，业务调用 DB 才报错)
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/demo

# JWT (开发可选 — 不设会用一次性随机 secret；生产环境必须设置)
# JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=30d

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# OpenRouter 免费模型（推荐的默认免费入口）
# 前端“OpenRouter 免费模型”预设会使用这里的服务端 Key，用户无需填写 Key。
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_FREE_MODEL=openrouter/free
# OPENROUTER_HTTP_REFERER=http://localhost:3001
# OPENROUTER_APP_TITLE=AI小说第一步

# AI Horde 公共模型池（可选）
# 不填时使用匿名低优先级账号 0000000000；填入自己的 Horde Key 可提升排队优先级。
# AI_HORDE_API_KEY=0000000000
# AI_HORDE_MODEL=aphrodite/TheDrummer/Cydonia-24B-v4.3
# AI_HORDE_MAX_LENGTH=2048
# AI_HORDE_MAX_LENGTH_CAP=3072

# 免费共享算力（可选）
# 用于前端“免费共享算力”入口。要求目标服务兼容 OpenAI Chat Completions。
# 共享线路可能排队、超时、质量波动或不适合敏感文本；生产环境建议加限流和审计。
# SHARED_GPU_BASE_URL=https://your-shared-gpu.example.com/v1
# SHARED_GPU_MODEL=your-model-id
# SHARED_GPU_API_KEY=optional-backend-only-key
# SHARED_GPU_JSON_MODE=false
