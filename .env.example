# Docker Compose local deployment
WEB_PORT=3000
API_PORT=3001
POSTGRES_PORT=5432

# PostgreSQL
POSTGRES_USER=novel
POSTGRES_PASSWORD=novel
POSTGRES_DB=ai_novel_first_step

# API
NODE_ENV=development
JWT_SECRET=local-dev-secret

# Browser-facing API URL used by the Next.js app.
# Keep this relative so production browsers call the web app proxy instead of localhost.
NEXT_PUBLIC_API_BASE_URL=/api/v1
API_INTERNAL_BASE_URL=http://localhost:3001/api/v1

# Optional shared OpenAI-compatible model endpoint used by the "免费共享算力" preset.
# Leave blank to disable the shared endpoint and use your own model key in the UI.
SHARED_GPU_BASE_URL=
SHARED_GPU_MODEL=
SHARED_GPU_API_KEY=
SHARED_GPU_JSON_MODE=false

# Enable response_format=json_schema for OpenAI-compatible providers beyond official OpenAI/Azure OpenAI URLs.
# Keep false unless your provider explicitly supports JSON Schema structured outputs.
ENABLE_OPENAI_COMPAT_JSON_SCHEMA=false
