{
	"name": "web",
	"version": "0.1.0",
	"private": true,
	"license": "MIT",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"format": "oxfmt --check package.json next.config.ts postcss.config.mjs components.json tsconfig.json src",
		"format:fix": "oxfmt --write package.json next.config.ts postcss.config.mjs components.json tsconfig.json src",
		"check": "pnpm run lint && pnpm run format",
		"check:fix": "pnpm run lint:fix && pnpm run format:fix"
	},
	"dependencies": {
		"@radix-ui/react-avatar": "^1.1.11",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"axios": "^1.13.5",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.563.0",
		"next": "^16.1.6",
		"next-themes": "^0.4.6",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"sonner": "^2.0.7",
		"swr": "^2.4.0",
		"tailwind-merge": "^3.4.0",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.1.18",
		"@types/node": "^25.2.2",
		"@types/react": "^19.2.13",
		"@types/react-dom": "^19.2.3",
		"git-cz": "^4.9.0",
		"lint-staged": "^16.2.7",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"postcss": "^8.5.6",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,mjs,cjs}": [
			"oxlint --fix",
			"oxfmt --write --no-error-on-unmatched-pattern"
		],
		"*.{json,md,css,scss,html,yml,yaml}": [
			"oxfmt --write --no-error-on-unmatched-pattern"
		]
	},
	"packageManager": "pnpm@10.14.0"
}
